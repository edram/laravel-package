{
    "name": "Laravel Package Dev Container",
    "dockerComposeFile": "docker-compose.yml",
    "service": "laravel-package",
    "workspaceFolder": "/laravel-package",
    "remoteUser": "root",
    "features": {},
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined"
    ],
    "customizations": {
        "vscode": {
            "extensions": []
        }
    },
    "mounts": [
        "source=${localEnv:HOME}/.ssh/authorized_keys,target=/root/.ssh/authorized_keys,type=bind"
    ]
}