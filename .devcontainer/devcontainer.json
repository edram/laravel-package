{
    "name": "Laravel Package Dev Container",
    "dockerComposeFile": "docker-compose.yml",
    "service": "laravel-package",
    "workspaceFolder": "/larave-package",
    "remoteUser": "root",
    "features": {},
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined"
    ],
    "customizations": {
        "vscode": {
            "extensions": []
        }
    }
}